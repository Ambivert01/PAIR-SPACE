PORT=5000
MONGO_URI=mongodb://localhost:27017/pairspace
JWT_SECRET=your_strong_secret_here_min_32_chars
CLIENT_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379

# Media limits (MB)
MAX_IMAGE_MB=10
MAX_VIDEO_MB=100
MAX_AUDIO_MB=20
MAX_FILE_MB=50

# Database backup configuration
BACKUP_DIR=./backups
DB_NAME=pairspace
CONFIRM_RESTORE=false

# Sentry error tracking (production only)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Logging configuration
LOG_DIR=./logs
NODE_ENV=development

# Alert thresholds
ALERT_ERROR_RATE=10
ALERT_SLOW_REQUEST_RATE=20
ALERT_DB_FAILURE_RATE=3
ALERT_AI_FAILURE_RATE=5
ALERT_MEDIA_FAILURE_RATE=5
ALERT_WEBHOOK_URL=
