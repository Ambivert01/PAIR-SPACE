# ── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas — replace <user>, <password>, <cluster> with your values
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pairspace?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=<your_strong_secret_min_32_chars>

# ── CORS ────────────────────────────────────────────────────────────────────
CLIENT_URL=https://app.pairspace.com

# ── Redis ───────────────────────────────────────────────────────────────────
# Redis Cloud or Upstash — leave empty to use in-memory fallback
REDIS_URL=redis://:<password>@<host>:<port>

# ── Media Limits (MB) ───────────────────────────────────────────────────────
MAX_IMAGE_MB=10
MAX_VIDEO_MB=100
MAX_AUDIO_MB=20
MAX_FILE_MB=50

# ── Feature Flags (uncomment to disable) ────────────────────────────────────
# DISABLE_AI_INSIGHTS=true
# DISABLE_GAMES=true
# DISABLE_GIFTS=true
# DISABLE_TIME_CAPSULES=true
# DISABLE_JOURNAL=true
# DISABLE_STORY_ENGINE=true
# DISABLE_PLUGIN_SYSTEM=true
# DISABLE_OFFLINE_SYNC=true
# DISABLE_MULTI_REL=true
