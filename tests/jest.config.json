{
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {},
  "testMatch": [
    "<rootDir>/backend/**/*.test.js",
    "<rootDir>/socket/**/*.test.js",
    "<rootDir>/utils/**/*.test.js"
  ],
  "coverageThreshold": {
    "global": { "lines": 70, "functions": 70, "branches": 60 }
  },
  "testTimeout": 15000
}
