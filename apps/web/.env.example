# API Configuration
# For local development: Leave empty to use Vite proxy (recommended)
# The proxy in vite.config.js forwards /api and /socket.io requests to http://localhost:5000
# For production: Set to your production API URL
VITE_API_URL=
VITE_SOCKET_URL=

# Sentry error tracking (production only)
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_SESSION_RATE=0.1
VITE_SENTRY_REPLAY_ERROR_RATE=1.0

# App version (for release tracking)
VITE_APP_VERSION=1.0.0
